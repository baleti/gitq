#compdef gitq
# zsh completion for the gitq pipeline CLI tool.
#
# Install: `make install-zsh` in the repo root (symlinks this file into
# ${XDG_DATA_HOME:-~/.local/share}/zsh/completions), or copy/symlink it
# into any directory on your $fpath yourself. Then in ~/.zshrc, before
# compinit:
#   fpath=(~/.local/share/zsh/completions $fpath)
#   autoload -Uz compinit && compinit
#
# How it works:
#   gitq takes its entire pipeline as a single string argument, so completion
#   happens *within* that argument.  We split the typed prefix on whitespace,
#   set IPREFIX to everything before the last (partial) word, and delegate
#   candidate generation to `gitq --complete PREFIX` which prints one candidate
#   per line.  This way the completion logic lives in the gitq binary itself
#   and is shared with the Emacs integration.

_gitq() {
  # Only complete the first (pipeline) argument.
  if (( CURRENT != 2 )); then
    return 1
  fi

  # PREFIX = everything the user has typed so far for this argument.
  # We split it to separate the partial word from the already-complete prefix.
  local -a typed_words
  typed_words=("${(z)PREFIX}")       # (z) splits respecting shell quoting

  local partial=""
  local before=""

  if [[ ${#typed_words[@]} -gt 0 ]]; then
    partial="${typed_words[-1]}"
    if [[ ${#typed_words[@]} -gt 1 ]]; then
      typed_words[-1]=()
      before="${(j: :)typed_words} "
    fi
  fi

  # Tell zsh that IPREFIX (the non-completing prefix) is `before`,
  # and PREFIX (the part we're replacing) is `partial`.
  IPREFIX+="$before"
  PREFIX="$partial"
  SUFFIX=""

  # Ask gitq for candidates given everything typed so far (before + partial).
  local full_prefix="${before}${partial}"
  local -a candidates
  candidates=(${(f)"$(gitq --complete "$full_prefix" 2>/dev/null)"})

  if [[ ${#candidates[@]} -eq 0 ]]; then
    return 1
  fi

  # Group candidates by type for a nicer completion menu.
  local -a sources steps terminals morphisms fields operators
  sources=(commits branches tags refs worktrees blobs HEAD)
  steps=(via where grep pickaxe path pick take skip first last sort in)
  terminals=(/show /copy /insert /count /branch-off /amend /squash
             /reword /remove /delete /commit /stage /mark /worktree)
  morphisms=(parent 'parent*' 'parent+' tree tree.blobs tree.subtrees
             tree.entries diff diff.hunks diff.lines history commit)
  fields=(sha author email date message path name branch parents-count)
  operators=(== != '>' '<' '>=' '<=' regex after before within is)

  local -a src_cands step_cands term_cands morph_cands field_cands op_cands other_cands
  for c in $candidates; do
    if (( ${sources[(Ie)$c]} )); then
      src_cands+=("$c")
    elif (( ${terminals[(Ie)$c]} )); then
      term_cands+=("$c")
    elif (( ${morphisms[(Ie)$c]} )); then
      morph_cands+=("$c")
    elif (( ${fields[(Ie)$c]} )); then
      field_cands+=("$c")
    elif (( ${operators[(Ie)$c]} )); then
      op_cands+=("$c")
    elif (( ${steps[(Ie)$c]} )); then
      step_cands+=("$c")
    else
      other_cands+=("$c")
    fi
  done

  local expl
  [[ ${#src_cands[@]}   -gt 0 ]] && { _description gitq-src   expl 'source';    compadd "$expl[@]" -- $src_cands   }
  [[ ${#step_cands[@]}  -gt 0 ]] && { _description gitq-step  expl 'step';      compadd "$expl[@]" -- $step_cands  }
  [[ ${#morph_cands[@]} -gt 0 ]] && { _description gitq-morph expl 'morphism';  compadd "$expl[@]" -- $morph_cands }
  [[ ${#field_cands[@]} -gt 0 ]] && { _description gitq-field expl 'field';     compadd "$expl[@]" -- $field_cands }
  [[ ${#op_cands[@]}    -gt 0 ]] && { _description gitq-op    expl 'operator';  compadd "$expl[@]" -- $op_cands    }
  [[ ${#term_cands[@]}  -gt 0 ]] && { _description gitq-term  expl '/terminal'; compadd "$expl[@]" -- $term_cands  }
  [[ ${#other_cands[@]} -gt 0 ]] && { _description gitq-other expl 'value';     compadd "$expl[@]" -- $other_cands }
}

_gitq "$@"
